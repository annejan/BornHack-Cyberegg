{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "Debug embassy (nRF52840)",
            "cwd": "${workspaceFolder}",
            "connectUnderReset": false,
            "chip": "nRF52840_xxAA",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${workspaceFolder}/target/thumbv7em-none-eabihf/debug/embassy",
                    "rttEnabled": true
                }
            ],
            "preLaunchTask": "cargo fw"
        }
    ]
}
